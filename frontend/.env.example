# ===================================
# Application Settings
# ===================================
ENVIRONMENT=production
DEBUG=False
LOG_LEVEL=INFO

# ===================================
# Server Configuration
# ===================================
HOST=0.0.0.0
PORT=8501

# ===================================
# API Configuration
# ===================================
# Base URL of your backend API
API_URL=http://localhost:8000

# ===================================
# Authentication
# ===================================
AUTH_ENABLED=True
# Generate a secure secret key: openssl rand -hex 32
SESSION_SECRET_KEY=your-secure-session-secret-key-here

# ===================================
# CORS Configuration
# ===================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:8501,http://localhost:3000,http://localhost:8000

# ===================================
# Feature Flags
# ===================================
FEATURE_ANALYTICS=False
FEATURE_DARK_MODE=True

# ===================================
# UI/UX Settings
# ===================================
DEFAULT_THEME=light
ITEMS_PER_PAGE=10

# ===================================
# Performance
# ===================================
API_TIMEOUT=30  # seconds
CACHE_TTL=300  # 5 minutes

# ===================================
# Monitoring & Logging
# ===================================
# Sentry DSN (https://sentry.io)
SENTRY_DSN=your-sentry-dsn-here

# ===================================
# External Services
# ===================================
# Add any additional external service configurations here

# Example:
# GOOGLE_ANALYTICS_ID=your-ga-id
# MIXPANEL_TOKEN=your-mixpanel-token
# INTERCOM_APP_ID=your-intercom-app-id
